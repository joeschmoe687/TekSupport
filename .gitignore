# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/build/
android/app/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Release signing
android/key.properties
android/app/upload-keystore.jks
node_modules

# Build artifacts (folders with spaces/numbers from copy operations)
.dart_tool*/
.flutter-plugins-dependencies*
build*/
android_backup_*/
android/app/build*/

# Flutter generated/ephemeral files (all platforms)
ios/Flutter/ephemeral*/
ios/Flutter/Generated*.xcconfig
ios/Flutter/flutter_export_environment*.sh
ios/Runner/GeneratedPluginRegistrant*.m
ios/Runner/GeneratedPluginRegistrant*.h
linux/flutter/ephemeral*/
macos/Flutter/ephemeral*/
windows/flutter/ephemeral*/

# Large logs
logs/
*.log
*.hive

# Environment files
.env
.env.local
.env.*.local
.env.*.production
functions/.env
functions/.env.local
functions/.env.*.local

# Secrets and credentials
**/secrets.json
**/*.key
**/*.pem
**/private-key.json

# BLE Sniffing bugreports (large)
docs/BLE-Sniffing/*.zip
docs/BLE-Sniffing/*_extracted/
docs/BLE-Sniffing/phone-data/
docs/BLE-Sniffing/extracted_*/
docs/BLE-Sniffing/bugreport_*/
docs/BLE-Sniffing/ble_sniff_extract/

# IDE
.vscode/

# Test artifacts
test_results/
coverage/
integration_test_report.txt
*.test.log
