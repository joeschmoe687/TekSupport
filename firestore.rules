rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Helper function to check if user is tech or admin
    function isTechOrAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'tech'] ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      // Techs and admins can read all profiles (for chat display names)
      allow read: if isAuthenticated() && (request.auth.uid == userId || isTechOrAdmin());
      
      // Users can create their own profile, but cannot set authorization fields
      allow create: if isAuthenticated()
                    && request.auth.uid == userId
                    && !('role' in request.resource.data.keys())
                    && !('isAdmin' in request.resource.data.keys());

      // Users can update their own profile, but cannot modify authorization fields
      allow update: if isAuthenticated()
                    && request.auth.uid == userId
                    && !('role' in request.resource.data.diff(resource.data).changedKeys())
                    && !('isAdmin' in request.resource.data.diff(resource.data).changedKeys());
      
      // Admins can write any profile (for role management and other changes)
      allow write: if isAdmin();
    }
    
    // Support rooms (chat sessions)
    match /supportRooms/{roomId} {
      // Users can read rooms they created
      // Admins and techs can read all rooms
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         resource.data.customerUID == request.auth.uid ||
         isTechOrAdmin());
      
      // Users can create their own rooms
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own rooms, admins/techs can update any
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         resource.data.customerUID == request.auth.uid ||
         isTechOrAdmin());
      
      // Only admins can delete rooms
      allow delete: if isAdmin();
      
      // Messages subcollection
      match /messages/{messageId} {
        // Only room participants and techs/admins can read messages
        allow read: if isAuthenticated() && 
          (get(/databases/$(database)/documents/supportRooms/$(roomId)).data.userId == request.auth.uid ||
           get(/databases/$(database)/documents/supportRooms/$(roomId)).data.customerUID == request.auth.uid ||
           isTechOrAdmin());
        
        // Only room participants and techs/admins can create messages
        allow create: if isAuthenticated() && 
          (get(/databases/$(database)/documents/supportRooms/$(roomId)).data.userId == request.auth.uid ||
           get(/databases/$(database)/documents/supportRooms/$(roomId)).data.customerUID == request.auth.uid ||
           isTechOrAdmin());
        
        // Only room participants and techs/admins can update messages
        allow update: if isAuthenticated() && 
          (get(/databases/$(database)/documents/supportRooms/$(roomId)).data.userId == request.auth.uid ||
           get(/databases/$(database)/documents/supportRooms/$(roomId)).data.customerUID == request.auth.uid ||
           isTechOrAdmin());
        
        // Only admins can delete messages
        allow delete: if isAdmin();
      }
    }
    
    // Support sessions (alternate chat collection)
    match /supportSessions/{sessionId} {
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isTechOrAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isTechOrAdmin());
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        // Only session participants and techs/admins can read messages
        allow read: if isAuthenticated() && 
          (get(/databases/$(database)/documents/supportSessions/$(sessionId)).data.userId == request.auth.uid ||
           isTechOrAdmin());
        
        // Only session participants and techs/admins can create messages
        allow create: if isAuthenticated() && 
          (get(/databases/$(database)/documents/supportSessions/$(sessionId)).data.userId == request.auth.uid ||
           isTechOrAdmin());
        
        // Only session participants and techs/admins can update messages
        allow update: if isAuthenticated() && 
          (get(/databases/$(database)/documents/supportSessions/$(sessionId)).data.userId == request.auth.uid ||
           isTechOrAdmin());
        
        // Only admins can delete messages
        allow delete: if isAdmin();
      }
    }
    
    // Customers collection
    match /customers/{customerId} {
      // Only admins and techs can access
      allow read, write: if isTechOrAdmin();
    }
    
    // Jobs collection
    match /jobs/{jobId} {
      // Users can read jobs assigned to them OR jobs they created
      // Admins and techs can read/write all jobs
      allow read: if isAuthenticated() && 
        (resource.data.assignedTo == request.auth.uid || 
         resource.data.userId == request.auth.uid ||
         resource.data.customerUID == request.auth.uid ||
         isTechOrAdmin());
      // Users can create jobs
      allow create: if isAuthenticated();
      // Users can update their own jobs, admins/techs can update any
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         resource.data.customerUID == request.auth.uid ||
         isTechOrAdmin());
      allow delete: if isAdmin();
    }
    
    // Job dispatch
    match /jobDispatch/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isTechOrAdmin();
    }
    
    // BLE sniffer logs (for device learning)
    match /ble_sniff_logs/{logId} {
      // Techs and admins can read/write
      allow read, write: if isTechOrAdmin();
    }
    
    // App error logs (automated error reporting)
    match /app_error_logs/{logId} {
      // ANY user (even not logged in) can create error logs
      // This is critical for debugging app crashes
      allow create: if true;
      // Techs and admins can read all error logs
      allow read: if isTechOrAdmin();
      // No one can update or delete (immutable logs)
      allow update, delete: if false;
    }
    
    // Support transactions (payment logs)
    match /supportTransactions/{transactionId} {
      // Users can read their own transactions
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Admins can read all transactions
      allow read: if isAdmin();
      
      // Users can create their own transactions
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Only system (Cloud Functions) can update transaction status
      // Block direct updates from clients
      allow update: if false;
      
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // Settings collection
    match /settings/{setting} {
      // Everyone can read settings (pricing, config)
      allow read: if true;
      
      // Only admins can write settings
      allow write: if isAdmin();
    }
    
    // Live device data (for web UI viewing)
    match /live_device_data/{userId} {
      // Users can read/write their own live data
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      // Admins can read all live data
      allow read: if isAdmin();
      
      // Subcollection for device readings
      match /readings/{deviceId} {
        // Users can read/write their own device readings
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated() && 
                       request.auth.uid == userId &&
                       // Validate data structure
                       request.resource.data.keys().hasAll(['deviceId', 'deviceName', 'type', 'value', 'unit']) &&
                       request.resource.data.deviceId is string &&
                       request.resource.data.deviceName is string &&
                       request.resource.data.type is string &&
                       request.resource.data.value is number &&
                       request.resource.data.unit is string &&
                       // Battery level must be 0-100 if present
                       (!request.resource.data.keys().hasAny(['batteryLevel']) || 
                        (request.resource.data.batteryLevel is int && 
                         request.resource.data.batteryLevel >= 0 && 
                         request.resource.data.batteryLevel <= 100));
        
        // Admins can read all device readings
        allow read: if isAdmin();
      }
    }
    
    // ==========================================================================
    // TEKMATE - ADMIN ONLY (GHOST MODE) - CRITICAL SECURITY
    // ==========================================================================
    // TekMate interactions, logs, and data are COMPLETELY HIDDEN from non-admins
    // Non-admins cannot read, write, or even know this collection exists
    match /admin/{document=**} {
      // ONLY authenticated admins can access anything under /admin
      allow read, write: if isAdmin();
    }
    
    // Explicitly block any direct access to TekMate logs
    match /tekmate_interactions/{document=**} {
      // Blocked - should be under /admin collection
      allow read, write: if false;
    }
    
    // Job workflow steps
    match /jobSteps/{stepId} {
      // Users can read steps for jobs they're assigned to or created
      // Admins/techs can read all steps
      allow read: if isAuthenticated();
      
      // Users can create steps for their jobs
      // Admins/techs can create any steps
      allow create: if isAuthenticated();
      
      // Users can update steps for their jobs
      // Admins/techs can update any steps
      allow update: if isAuthenticated();
      
      // Only admins can delete steps
      allow delete: if isAdmin();
    }
    
    // Invoices collection
    match /invoices/{invoiceId} {
      // Users can read their own invoices
      allow read: if isAuthenticated() && 
        (resource.data.customerId == request.auth.uid || 
         resource.data.userId == request.auth.uid);
      
      // Admins/techs can read all invoices
      allow read: if isTechOrAdmin();
      
      // Only admins/techs can create/update invoices
      allow create, update: if isTechOrAdmin();
      
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // Error logs (for error reporting from all platforms)
    match /errorLogs/{logId} {
      // Any authenticated user can create error logs
      allow create: if request.auth != null;
      // Only admins and techs can read error logs
      allow read: if isTechOrAdmin();
      // No one can update error logs (immutable)
      allow update: if false;
      // Only admins can delete error logs
      allow delete: if isAdmin();
    }
    
    // Pricebook categories
    match /pricebookCategories/{categoryId} {
      // Everyone can read pricing (public info)
      allow read: if true;
      
      // Only admins can modify pricing
      allow write: if isAdmin();
    }
    
    // Settings collection (app config, pricing, Stripe keys)
    match /settings/{setting} {
      // Everyone can read settings (pricing, config)
      allow read: if true;
      
      // Only admins can write settings
      allow write: if isAdmin();
    }
    
    // Default deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
